{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirror-cartographer.local/schemas/automation-execution-ledger.schema.json",
  "title": "AutomationExecutionLedger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "run_date",
    "requested_by_user",
    "records",
    "synthesis_allowed_after_ledger"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Stable identifier for this manual automation execution pass."
    },
    "run_date": {
      "type": "string",
      "format": "date"
    },
    "requested_by_user": {
      "type": "boolean"
    },
    "synthesis_allowed_after_ledger": {
      "type": "boolean",
      "const": true,
      "description": "Synthesis is allowed only after each automation has its own record."
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/AutomationExecutionRecord"
      }
    }
  },
  "$defs": {
    "AutomationExecutionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automation_name",
        "original_task_interpretation",
        "execution_mode",
        "inputs_checked",
        "research_performed",
        "evidence_status",
        "implementation_performed",
        "state_change_proof",
        "blocked_or_incomplete_parts",
        "next_executable_action"
      ],
      "properties": {
        "automation_name": {
          "type": "string"
        },
        "original_task_interpretation": {
          "type": "string"
        },
        "execution_mode": {
          "type": "string",
          "enum": [
            "scheduled_runtime_unavailable",
            "manual_equivalent_run",
            "partial_manual_run",
            "documentation_only",
            "github_write_completed",
            "github_write_blocked"
          ]
        },
        "inputs_checked": {
          "type": "array",
          "items": { "type": "string" }
        },
        "research_performed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_status": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "current_web_checked",
              "github_checked",
              "repo_state_checked",
              "source_bound",
              "inference_only",
              "not_current_checked",
              "needs_primary_sources",
              "needs_user_context",
              "unsafe_to_publish_raw"
            ]
          }
        },
        "implementation_performed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "state_change_proof": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["commit", "issue", "pull_request", "no_state_change", "blocked_error"]
            },
            "commit_sha": { "type": "string" },
            "issue_number": { "type": "integer" },
            "pull_request_number": { "type": "integer" },
            "file_paths": {
              "type": "array",
              "items": { "type": "string" }
            },
            "error": { "type": "string" }
          }
        },
        "blocked_or_incomplete_parts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_executable_action": {
          "type": "string"
        }
      }
    }
  }
}
