{
  "name": "mirror-cartographer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run build",
    "test:agency": "node --test tools/agency-validation/*.test.mjs",
    "fixture-parity:smoke": "node tools/agency-validation/run-fixture-parity.mjs --report-out artifacts/agency-validation/fixture-parity-report.json",
    "verify:agency": "npm run test:agency && npm run fixture-parity:smoke",
    "test:governance": "node --test tools/governance-validation/*.test.mjs tools/lib/*.test.mjs",
    "verify:governance": "npm run test:governance"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": "15.3.5"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "@eslint/eslintrc": "^3",
    "ajv": "^8.17.1"
  }
}
