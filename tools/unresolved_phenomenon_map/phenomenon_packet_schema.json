{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/phenomenon_packet_schema.json",
  "title": "Mirror Cartographer Unresolved Phenomenon Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "packet_id",
    "phenomenon_label",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "implementation_status",
    "testability",
    "observed_pattern",
    "operational_variables",
    "boundary_conditions",
    "alternative_explanations",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "record_type": { "const": "unresolved_phenomenon_packet" },
    "packet_id": { "type": "string", "minLength": 8, "pattern": "^[a-z0-9_\\-]+$" },
    "phenomenon_label": { "type": "string", "minLength": 8 },
    "source_status": { "enum": ["synthetic", "public_primary", "public_secondary", "public_institutional", "deidentified_observation"] },
    "claim_status": { "enum": ["unresolved", "candidate_pattern", "rejected_as_unbounded"] },
    "privacy_status": { "enum": ["public_safe", "deidentified", "reject_private"] },
    "missingness": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 3 } },
    "revision_reason": { "type": "string", "minLength": 12 },
    "implementation_status": { "enum": ["schema_only", "validated", "wired_to_pipeline"] },
    "testability": { "enum": ["high", "moderate", "low", "blocked"] },
    "observed_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "pattern_type", "time_window", "recurrence_signal"],
      "properties": {
        "description": { "type": "string", "minLength": 20 },
        "pattern_type": { "enum": ["temporal", "contextual", "transition", "dose_response_like", "interaction", "contradiction", "measurement_gap"] },
        "time_window": { "type": "string", "minLength": 3 },
        "recurrence_signal": { "enum": ["single_event", "repeated", "unknown"] }
      }
    },
    "operational_variables": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "measurement_method", "unit_or_scale"],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "role": { "enum": ["input", "output", "context", "confounder", "stratifier"] },
          "measurement_method": { "type": "string", "minLength": 5 },
          "unit_or_scale": { "type": "string", "minLength": 2 }
        }
      }
    },
    "boundary_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 8 } },
    "alternative_explanations": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 8 } },
    "falsification_route": { "type": "string", "minLength": 20 },
    "next_executable_action": { "type": "string", "minLength": 12 }
  }
}
