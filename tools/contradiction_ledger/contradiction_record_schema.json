{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirror-cartographer.local/schemas/contradiction_record_schema.json",
  "title": "Mirror Cartographer Contradiction Record",
  "description": "Public-safe schema for recording failed, contradicted, or ambiguous discovery claims as searchable research infrastructure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "timestamp_utc",
    "title",
    "hypothesis_reference",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "implementation_status",
    "testability",
    "evidence_strength",
    "contradiction_status",
    "contradiction_summary",
    "expected_result",
    "observed_result",
    "possible_explanations",
    "measurable_variables",
    "falsification_route",
    "next_executable_action",
    "linked_artifacts"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_type": { "const": "contradiction_record" },
    "id": {
      "type": "string",
      "pattern": "^cr-[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "title": { "type": "string", "minLength": 8 },
    "hypothesis_reference": { "type": "string", "minLength": 3 },
    "source_status": {
      "type": "string",
      "enum": [
        "synthetic_fixture",
        "public_source_map",
        "assistant_generated_public_safe",
        "repository_internal_public_safe"
      ]
    },
    "claim_status": {
      "type": "string",
      "enum": [
        "failed_hypothesis",
        "contradicted_hypothesis",
        "ambiguous_result",
        "needs_replication",
        "engineering_regression"
      ]
    },
    "privacy_status": {
      "type": "string",
      "enum": [
        "public_safe",
        "synthetic_only",
        "public_source_only",
        "abstracted_no_private_details"
      ]
    },
    "missingness": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "revision_reason": { "type": "string", "minLength": 10 },
    "implementation_status": {
      "type": "string",
      "enum": [
        "schema_only",
        "fixture_only",
        "validator_ready",
        "tested",
        "integrated"
      ]
    },
    "testability": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "evidence_strength": {
      "type": "string",
      "enum": ["synthetic", "weak", "moderate", "strong", "replicated"]
    },
    "contradiction_status": {
      "type": "string",
      "enum": ["not_a_contradiction", "candidate_contradiction", "confirmed_contradiction", "ambiguous_missing_data"]
    },
    "contradiction_summary": { "type": "string", "minLength": 20 },
    "expected_result": { "type": "string", "minLength": 10 },
    "observed_result": { "type": "string", "minLength": 10 },
    "possible_explanations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 5 }
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "unit", "expected_direction", "observed_direction", "measurement_status"],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "unit": { "type": "string", "minLength": 1 },
          "expected_direction": { "type": "string", "enum": ["increase", "decrease", "stable", "present", "absent", "unknown"] },
          "observed_direction": { "type": "string", "enum": ["increase", "decrease", "stable", "present", "absent", "unknown"] },
          "measurement_status": { "type": "string", "enum": ["measured", "proxy", "missing", "simulated"] }
        }
      }
    },
    "falsification_route": { "type": "string", "minLength": 20 },
    "next_executable_action": { "type": "string", "minLength": 12 },
    "linked_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "contradiction_status": { "const": "confirmed_contradiction" } }
      },
      "then": {
        "properties": {
          "claim_status": { "enum": ["failed_hypothesis", "contradicted_hypothesis", "engineering_regression"] },
          "evidence_strength": { "enum": ["moderate", "strong", "replicated"] }
        }
      }
    },
    {
      "if": {
        "properties": { "contradiction_status": { "const": "ambiguous_missing_data" } }
      },
      "then": {
        "properties": {
          "claim_status": { "enum": ["ambiguous_result", "needs_replication"] }
        }
      }
    }
  ]
}
