{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/interaction_trajectory_gate/trajectory_packet_schema.json",
  "title": "MC Interaction Trajectory Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "source_status",
    "claim_status",
    "privacy_status",
    "interaction_window",
    "research_state_before",
    "research_state_after",
    "trajectory_metrics",
    "sensemaking_events",
    "falsification_route",
    "missingness",
    "revision_reason",
    "implementation_status"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "packet_id": {"type": "string", "pattern": "^itp_[a-z0-9_\\-]+$"},
    "source_status": {"enum": ["synthetic", "public_research", "mixed_public_synthetic"]},
    "claim_status": {"enum": ["infrastructure_hypothesis", "evaluation_claim", "prototype_requirement"]},
    "privacy_status": {"enum": ["public_safe", "deidentified", "reject_private"]},
    "interaction_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turn_count", "started_at", "ended_at"],
      "properties": {
        "turn_count": {"type": "integer", "minimum": 2},
        "started_at": {"type": "string"},
        "ended_at": {"type": "string"}
      }
    },
    "research_state_before": {"$ref": "#/$defs/research_state"},
    "research_state_after": {"$ref": "#/$defs/research_state"},
    "trajectory_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_stability_delta",
        "measurability_delta",
        "falsifiability_delta",
        "privacy_risk_delta",
        "unsupported_promotion_count",
        "drift_count"
      ],
      "properties": {
        "claim_stability_delta": {"type": "number"},
        "measurability_delta": {"type": "number"},
        "falsifiability_delta": {"type": "number"},
        "privacy_risk_delta": {"type": "number", "maximum": 0},
        "unsupported_promotion_count": {"type": "integer", "minimum": 0},
        "drift_count": {"type": "integer", "minimum": 0}
      }
    },
    "sensemaking_events": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/sensemaking_event"}
    },
    "falsification_route": {"type": "string", "minLength": 20},
    "missingness": {"type": "array", "items": {"type": "string"}},
    "revision_reason": {"type": "string", "minLength": 12},
    "implementation_status": {"enum": ["schema_only", "fixtures_added", "validator_added", "ci_integrated"]}
  },
  "$defs": {
    "research_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "measurable_variables", "evidence_boundary", "falsification_route_present"],
      "properties": {
        "claim": {"type": "string", "minLength": 8},
        "measurable_variables": {"type": "array", "items": {"type": "string"}},
        "evidence_boundary": {"enum": ["unbounded", "bounded", "verified"]},
        "falsification_route_present": {"type": "boolean"}
      }
    },
    "sensemaking_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_type", "input_state", "output_state", "rationale", "verification_status"],
      "properties": {
        "event_type": {"enum": ["clarify", "operationalize", "challenge", "retrieve", "revise", "reject"]},
        "input_state": {"type": "string"},
        "output_state": {"type": "string"},
        "rationale": {"type": "string", "minLength": 12},
        "verification_status": {"enum": ["not_checked", "source_checked", "test_checked", "rejected"]}
      }
    }
  }
}
