{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/temporal_science_forecast_gate.schema.json",
  "title": "Temporal Science Forecast Gate Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "research_domain",
    "source_status",
    "claim_status",
    "privacy_status",
    "evidence_cutoff",
    "forecast_horizon",
    "forecast_claim",
    "prior_work_dependencies",
    "collaborator_or_dataset_targets",
    "expected_contribution_shape",
    "evaluation_signal",
    "missingness",
    "revision_reason",
    "implementation_status",
    "evidence_strength",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 8 },
    "research_domain": { "type": "string", "minLength": 3 },
    "source_status": { "enum": ["primary", "institutional", "preprint", "benchmark", "dataset", "open_source", "mixed"] },
    "claim_status": { "enum": ["hypothesis", "evaluation_criterion", "schema", "prototype_requirement", "source_map", "opportunity_target"] },
    "privacy_status": { "enum": ["public_safe", "synthetic_only", "deidentified_required", "sensitive_blocked", "local_only"] },
    "evidence_cutoff": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "forecast_horizon": { "type": "string", "minLength": 4 },
    "forecast_claim": { "type": "string", "minLength": 30 },
    "prior_work_dependencies": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 8 } },
    "collaborator_or_dataset_targets": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 5 } },
    "expected_contribution_shape": { "type": "string", "minLength": 20 },
    "evaluation_signal": { "type": "string", "minLength": 20 },
    "missingness": { "type": "string", "minLength": 10 },
    "revision_reason": { "type": "string", "minLength": 10 },
    "implementation_status": { "enum": ["planned", "implemented_synthetic", "implemented_ci", "blocked"] },
    "evidence_strength": { "enum": ["weak", "moderate", "strong"] },
    "falsification_route": { "type": "string", "minLength": 25 },
    "next_executable_action": { "type": "string", "minLength": 10 }
  }
}
