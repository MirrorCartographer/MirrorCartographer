{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/prediction_packet_schema.json",
  "title": "Mirror Cartographer Falsifiable Prediction Packet",
  "description": "Public-safe schema for converting a candidate mechanism into measurable predictions with explicit failure conditions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "prediction_id",
    "mechanism_graph_id",
    "claim_id",
    "prediction_statement",
    "prediction_type",
    "measurable_variables",
    "expected_direction",
    "observation_window",
    "failure_condition",
    "alternative_outcomes",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "implementation_status",
    "testability",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "record_type": {"type": "string", "const": "falsifiable_prediction_packet"},
    "prediction_id": {"type": "string", "pattern": "^pred_[a-z0-9_\\-]+$"},
    "mechanism_graph_id": {"type": "string", "minLength": 3},
    "claim_id": {"type": "string", "minLength": 3},
    "prediction_statement": {"type": "string", "minLength": 40},
    "prediction_type": {
      "type": "string",
      "enum": ["temporal", "dose_response", "comparative", "threshold", "sequence", "negative_control"]
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "operational_definition", "unit_or_scale", "collection_method"],
        "properties": {
          "name": {"type": "string", "minLength": 2},
          "operational_definition": {"type": "string", "minLength": 20},
          "unit_or_scale": {"type": "string", "minLength": 1},
          "collection_method": {"type": "string", "minLength": 10}
        }
      }
    },
    "expected_direction": {
      "type": "string",
      "enum": ["increase", "decrease", "no_change", "nonlinear", "sequence_specific"]
    },
    "observation_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_rule", "end_rule", "minimum_repetitions"],
      "properties": {
        "start_rule": {"type": "string", "minLength": 10},
        "end_rule": {"type": "string", "minLength": 10},
        "minimum_repetitions": {"type": "integer", "minimum": 2}
      }
    },
    "failure_condition": {"type": "string", "minLength": 30},
    "alternative_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 20}
    },
    "source_status": {"type": "string", "enum": ["synthetic", "primary", "secondary", "preprint", "institutional"]},
    "claim_status": {"type": "string", "enum": ["proposed", "test_ready", "tested_supported", "tested_contradicted", "inconclusive"]},
    "privacy_status": {"type": "string", "enum": ["public_safe", "deidentified", "reject_private"]},
    "missingness": {"type": "array", "items": {"type": "string"}},
    "revision_reason": {"type": "string", "minLength": 20},
    "implementation_status": {"type": "string", "enum": ["planned", "implemented", "validated"]},
    "testability": {"type": "string", "enum": ["low", "moderate", "high"]},
    "falsification_route": {"type": "string", "minLength": 30},
    "next_executable_action": {"type": "string", "minLength": 20}
  }
}
