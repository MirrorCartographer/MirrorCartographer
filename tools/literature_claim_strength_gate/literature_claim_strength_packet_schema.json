{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MC Literature Claim Strength Packet",
  "type": "object",
  "required": [
    "packet_id",
    "domain",
    "hypothesis",
    "claim_status",
    "source_status",
    "privacy_status",
    "missingness",
    "evidence_items",
    "measurable_variables",
    "falsification_route",
    "promotion_decision"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "pattern": "^lit-strength-[a-z0-9-]+$"
    },
    "domain": {
      "type": "string",
      "enum": [
        "medical_ai_evidence_organization",
        "animal_care_evidence_map",
        "scientific_reasoning",
        "mechanistic_biology",
        "neuroscience",
        "longitudinal_health_data"
      ]
    },
    "hypothesis": {
      "type": "string",
      "minLength": 20
    },
    "claim_status": {
      "type": "string",
      "enum": [
        "question_prep_only",
        "literature_supported_association",
        "mechanistic_hypothesis",
        "unsupported",
        "contradicted"
      ]
    },
    "source_status": {
      "type": "string",
      "enum": [
        "synthetic_fixture",
        "primary_source_mapped",
        "preprint_mapped",
        "review_mapped",
        "mixed_sources_mapped"
      ]
    },
    "privacy_status": {
      "type": "string",
      "enum": [
        "public_safe",
        "deidentified_only",
        "private_rejected"
      ]
    },
    "missingness": {
      "type": "object",
      "required": [
        "known_missing_fields",
        "absence_interpretation"
      ],
      "properties": {
        "known_missing_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "absence_interpretation": {
          "type": "string",
          "enum": [
            "not_absence_of_effect",
            "not_absence_of_symptom",
            "not_applicable"
          ]
        }
      }
    },
    "evidence_items": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "source_type",
          "supports",
          "limits",
          "reproducibility_signal",
          "date_status"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 3
          },
          "source_type": {
            "type": "string",
            "enum": [
              "primary_research",
              "clinical_guideline",
              "dataset",
              "benchmark",
              "preprint",
              "review",
              "institutional_protocol",
              "synthetic"
            ]
          },
          "supports": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "limits": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "reproducibility_signal": {
            "type": "string",
            "enum": [
              "none",
              "low",
              "moderate",
              "high"
            ]
          },
          "date_status": {
            "type": "string",
            "enum": [
              "current",
              "possibly_stale",
              "historical",
              "synthetic"
            ]
          }
        }
      }
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "name",
          "unit_or_scale",
          "collection_boundary"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "unit_or_scale": {
            "type": "string"
          },
          "collection_boundary": {
            "type": "string",
            "enum": [
              "research_metadata_only",
              "deidentified_observation",
              "requires_clinician_or_vet_source",
              "not_collectable"
            ]
          }
        }
      }
    },
    "falsification_route": {
      "type": "object",
      "required": [
        "would_weaken_claim",
        "would_block_promotion"
      ],
      "properties": {
        "would_weaken_claim": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "would_block_promotion": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "promotion_decision": {
      "type": "string",
      "enum": [
        "promote_to_question_prep",
        "hold_for_more_sources",
        "route_to_contradiction_ledger",
        "reject_private_or_advice_like"
      ]
    }
  },
  "additionalProperties": false
}
