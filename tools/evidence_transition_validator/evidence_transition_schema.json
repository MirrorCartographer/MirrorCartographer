{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.local/schemas/evidence_transition_record.schema.json",
  "title": "Mirror Cartographer Evidence Transition Record",
  "description": "Public-safe schema for validating evidence-state transitions in discovery infrastructure. It is not a medical or veterinary decision tool.",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "transition_id",
    "claim_id",
    "from_state",
    "to_state",
    "transition_reason",
    "source_status",
    "claim_status",
    "privacy_status",
    "evidence_strength",
    "measurable_variables",
    "falsification_route",
    "timestamp_utc",
    "provenance",
    "missingness",
    "next_executable_action"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "record_type": {
      "type": "string",
      "const": "evidence_transition_record"
    },
    "transition_id": {
      "type": "string",
      "minLength": 3
    },
    "claim_id": {
      "type": "string",
      "minLength": 3
    },
    "from_state": {
      "$ref": "#/$defs/evidence_state"
    },
    "to_state": {
      "$ref": "#/$defs/evidence_state"
    },
    "transition_reason": {
      "type": "string",
      "minLength": 12
    },
    "source_status": {
      "type": "string",
      "enum": [
        "synthetic_fixture",
        "public_source",
        "public_safe_abstraction",
        "unverified_import",
        "mixed_sources"
      ]
    },
    "claim_status": {
      "type": "string",
      "enum": [
        "observation_only",
        "candidate_hypothesis",
        "mechanistic_model",
        "falsifiable_prediction",
        "test_result",
        "supported_by_test",
        "contradicted_by_test",
        "inconclusive"
      ]
    },
    "privacy_status": {
      "type": "string",
      "enum": [
        "synthetic_only",
        "public_safe",
        "deidentified_public_safe",
        "blocked_private_or_sensitive"
      ]
    },
    "evidence_strength": {
      "type": "string",
      "enum": [
        "none",
        "weak",
        "moderate",
        "strong",
        "contradictory",
        "insufficient"
      ]
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "operational_definition", "expected_direction"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "minLength": 2},
          "operational_definition": {"type": "string", "minLength": 8},
          "units": {"type": "string"},
          "expected_direction": {
            "type": "string",
            "enum": ["increase", "decrease", "change", "stable", "present", "absent", "unknown"]
          }
        }
      }
    },
    "falsification_route": {
      "type": "string",
      "minLength": 20
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "reference", "access_status"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["schema", "fixture", "validator", "paper", "dataset", "benchmark", "public_note", "human_review"]
          },
          "reference": {"type": "string", "minLength": 3},
          "access_status": {
            "type": "string",
            "enum": ["public", "synthetic", "public_safe_summary", "unavailable"]
          }
        }
      }
    },
    "missingness": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_executable_action": {
      "type": "string",
      "minLength": 12
    }
  },
  "$defs": {
    "evidence_state": {
      "type": "string",
      "enum": [
        "Observation",
        "Candidate Hypothesis",
        "Mechanistic Model",
        "Prediction",
        "Test Result",
        "Supported",
        "Contradicted",
        "Inconclusive"
      ]
    }
  }
}
