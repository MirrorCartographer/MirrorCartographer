{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MC Temporal Coherence Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "source_status",
    "claim_status",
    "privacy_status",
    "revision_reason",
    "implementation_status",
    "testability",
    "falsification_route",
    "measurable_variables",
    "observations"
  ],
  "properties": {
    "packet_id": {"type": "string", "minLength": 3},
    "source_status": {"enum": ["synthetic", "public_dataset", "literature_derived", "deidentified_research"]},
    "claim_status": {"enum": ["hypothesis", "test_fixture", "inconclusive", "supported", "contradicted"]},
    "privacy_status": {"enum": ["public_safe", "deidentified", "reject_private"]},
    "missingness": {"type": "string"},
    "revision_reason": {"type": "string", "minLength": 8},
    "implementation_status": {"enum": ["implemented", "planned", "experimental"]},
    "testability": {"type": "string", "minLength": 8},
    "falsification_route": {"type": "string", "minLength": 8},
    "measurable_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "unit", "directionality"],
        "properties": {
          "name": {"type": "string", "minLength": 2},
          "unit": {"type": "string", "minLength": 1},
          "directionality": {"enum": ["increase", "decrease", "change", "stable", "unknown"]}
        }
      }
    },
    "observations": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["time_index", "variable", "value_status", "collection_context", "evidence_boundary"],
        "properties": {
          "time_index": {"type": "integer", "minimum": 0},
          "variable": {"type": "string", "minLength": 2},
          "value": {},
          "value_status": {"enum": ["observed", "missing_unknown", "not_collected", "redacted", "not_applicable"]},
          "collection_context": {"type": "string", "minLength": 3},
          "evidence_boundary": {"enum": ["research_organization", "question_prep", "literature_mapping", "not_advice"]}
        }
      }
    }
  }
}
