{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirror-cartographer.local/schemas/experimental_action_unit_packet.schema.json",
  "title": "Experimental Action Unit Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "claim",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "implementation_status",
    "evidence_strength",
    "experimental_action_unit",
    "workflow_phase",
    "substrate_boundary",
    "blocked_inferences",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "packet_id": {"type": "string", "minLength": 6},
    "claim": {"type": "string", "minLength": 20},
    "source_status": {
      "type": "string",
      "enum": ["primary", "clinical_or_research_institution", "peer_reviewed", "preprint_caveated", "open_source", "benchmark_or_dataset", "synthetic_internal"]
    },
    "claim_status": {
      "type": "string",
      "enum": ["hypothesis", "prototype_requirement", "evaluation_criterion", "source_map", "collaborator_target", "opportunity_target", "blocked_claim"]
    },
    "privacy_status": {
      "type": "string",
      "enum": ["public_safe", "synthetic_only", "deidentified_required", "consent_required", "restricted_sensitive", "do_not_store"]
    },
    "missingness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["known_missing", "impact", "minimum_resolution"],
      "properties": {
        "known_missing": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
        "impact": {"type": "string", "minLength": 10},
        "minimum_resolution": {"type": "string", "minLength": 10}
      }
    },
    "revision_reason": {"type": "string", "minLength": 15},
    "implementation_status": {
      "type": "string",
      "enum": ["proposed", "schema_only", "validator_added", "fixtures_added", "tests_added", "implemented"]
    },
    "evidence_strength": {
      "type": "string",
      "enum": ["weak", "moderate", "strong", "unknown"]
    },
    "experimental_action_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "actor", "input", "operation", "output", "endpoint", "minimum_reproducible_unit"],
      "properties": {
        "action": {"type": "string", "minLength": 10},
        "actor": {"type": "string", "minLength": 3},
        "input": {"type": "string", "minLength": 5},
        "operation": {"type": "string", "minLength": 10},
        "output": {"type": "string", "minLength": 5},
        "endpoint": {"type": "string", "minLength": 10},
        "minimum_reproducible_unit": {"type": "string", "minLength": 20}
      }
    },
    "workflow_phase": {
      "type": "string",
      "enum": ["evidence_handling", "analysis", "design_and_optimization", "scientific_reasoning", "validation_and_operations", "translation", "scientific_communication"]
    },
    "substrate_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain", "species_or_population", "data_modality", "transfer_boundary"],
      "properties": {
        "domain": {"type": "string", "minLength": 3},
        "species_or_population": {"type": "string", "minLength": 3},
        "data_modality": {"type": "string", "minLength": 3},
        "transfer_boundary": {"type": "string", "minLength": 10}
      }
    },
    "blocked_inferences": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}},
    "falsification_route": {"type": "string", "minLength": 20},
    "next_executable_action": {"type": "string", "minLength": 10}
  }
}
