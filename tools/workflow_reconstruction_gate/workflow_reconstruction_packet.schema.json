{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/workflow_reconstruction_packet.schema.json",
  "title": "WorkflowReconstructionPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "research_question",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "implementation_status",
    "evidence_strength",
    "source_anchors",
    "boundary_conditions",
    "workflow_trace",
    "hypothesis_updates",
    "method_fit",
    "validation_route",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "packet_id": {"type": "string", "minLength": 6},
    "research_question": {"type": "string", "minLength": 20},
    "source_status": {"type": "string", "enum": ["primary", "clinical_research_institution", "preprint_with_caveat", "grant_or_prize_program", "dataset_or_benchmark", "open_source_tool", "synthetic_fixture"]},
    "claim_status": {"type": "string", "enum": ["hypothesis", "evaluation_criterion", "schema_requirement", "prototype_requirement", "source_map", "collaborator_target"]},
    "privacy_status": {"type": "string", "enum": ["public_safe_synthetic", "deidentified_research", "local_only_private", "restricted_sensitive", "unknown_reject"]},
    "missingness": {"type": "object", "additionalProperties": false, "required": ["status", "expected_missing_fields", "handling_rule"], "properties": {"status": {"type": "string", "enum": ["explicitly_modeled", "not_applicable", "unknown_reject"]}, "expected_missing_fields": {"type": "array", "items": {"type": "string"}}, "handling_rule": {"type": "string", "minLength": 10}}},
    "revision_reason": {"type": "string", "minLength": 15},
    "implementation_status": {"type": "string", "enum": ["proposed", "schema_only", "validator_built", "tests_built", "ci_wired", "deprecated"]},
    "evidence_strength": {"type": "string", "enum": ["low", "moderate", "high", "insufficient_reject"]},
    "source_anchors": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["name", "status", "date", "role"], "properties": {"name": {"type": "string", "minLength": 3}, "status": {"type": "string", "minLength": 3}, "date": {"type": "string", "pattern": "^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"}, "role": {"type": "string", "minLength": 10}}}},
    "boundary_conditions": {"type": "object", "additionalProperties": false, "required": ["dataset_or_context", "modality", "species_or_population", "time_boundary", "exclusion_boundary"], "properties": {"dataset_or_context": {"type": "string", "minLength": 5}, "modality": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "species_or_population": {"type": "string", "minLength": 3}, "time_boundary": {"type": "string", "minLength": 4}, "exclusion_boundary": {"type": "string", "minLength": 10}}},
    "workflow_trace": {"type": "array", "minItems": 3, "items": {"type": "object", "additionalProperties": false, "required": ["step", "input", "operation", "output", "reproducibility_note"], "properties": {"step": {"type": "integer", "minimum": 1}, "input": {"type": "string", "minLength": 3}, "operation": {"type": "string", "minLength": 8}, "output": {"type": "string", "minLength": 3}, "reproducibility_note": {"type": "string", "minLength": 10}}}},
    "hypothesis_updates": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["before", "evidence_trigger", "after", "decision"], "properties": {"before": {"type": "string", "minLength": 5}, "evidence_trigger": {"type": "string", "minLength": 5}, "after": {"type": "string", "minLength": 5}, "decision": {"type": "string", "enum": ["promote", "hold", "revise", "reject"]}}}},
    "method_fit": {"type": "object", "additionalProperties": false, "required": ["appropriateness_rationale", "known_limitations"], "properties": {"appropriateness_rationale": {"type": "string", "minLength": 20}, "known_limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5}}}},
    "validation_route": {"type": "string", "minLength": 20},
    "falsification_route": {"type": "string", "minLength": 20},
    "next_executable_action": {"type": "string", "minLength": 10}
  }
}
