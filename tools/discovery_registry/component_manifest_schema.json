{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mirror Cartographer Discovery Component Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "component_id",
    "name",
    "version",
    "category",
    "accepts",
    "produces",
    "entrypoint",
    "dependencies",
    "deterministic",
    "side_effects",
    "privacy_level",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "implementation_status",
    "testability",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "discovery_component_manifest"},
    "component_id": {"type": "string", "minLength": 3, "pattern": "^[a-z0-9_\\-]+$"},
    "name": {"type": "string", "minLength": 3},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "category": {"enum": ["validator", "generator", "transform", "evaluation", "prototype", "router"]},
    "accepts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
    "produces": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "function"],
      "properties": {
        "module": {"type": "string", "minLength": 3},
        "function": {"type": "string", "minLength": 2}
      }
    },
    "dependencies": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9_\\-]+$"}},
    "deterministic": {"type": "boolean"},
    "side_effects": {"type": "boolean"},
    "privacy_level": {"const": "public"},
    "source_status": {"enum": ["assistant_generated", "synthetic", "public_source", "mixed_public"]},
    "claim_status": {"enum": ["infrastructure", "test_fixture", "prototype", "not_scientific_claim"]},
    "privacy_status": {"const": "public_safe"},
    "missingness": {"type": "string", "minLength": 5},
    "revision_reason": {"type": "string", "minLength": 10},
    "implementation_status": {"enum": ["planned", "implemented", "tested", "deprecated"]},
    "testability": {"type": "string", "minLength": 10},
    "falsification_route": {"type": "string", "minLength": 10},
    "next_executable_action": {"type": "string", "minLength": 10}
  }
}
