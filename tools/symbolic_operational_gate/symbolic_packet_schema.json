{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/symbolic_operational_packet.schema.json",
  "title": "Mirror Cartographer Symbolic Operational Packet",
  "description": "Public-safe schema for translating symbolic or qualitative observations into operational variables with provenance, uncertainty, and falsification boundaries.",
  "type": "object",
  "required": [
    "schema_version",
    "packet_id",
    "source_status",
    "claim_status",
    "privacy_status",
    "symbolic_observation",
    "operational_translation",
    "measurable_variables",
    "uncertainty_notes",
    "missingness",
    "falsification_route",
    "boundary_risks",
    "next_executable_action"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "packet_id": {
      "type": "string",
      "minLength": 3
    },
    "source_status": {
      "type": "string",
      "enum": [
        "synthetic",
        "public_source",
        "public_safe_abstraction",
        "mixed_public_safe"
      ]
    },
    "claim_status": {
      "type": "string",
      "enum": [
        "observation",
        "hypothesis",
        "testable_hypothesis",
        "unsupported_claim",
        "rejected_claim"
      ]
    },
    "privacy_status": {
      "type": "string",
      "enum": [
        "synthetic_only",
        "public_safe_only",
        "deidentified_public_safe"
      ]
    },
    "symbolic_observation": {
      "type": "object",
      "required": ["label", "description", "context_frame"],
      "additionalProperties": false,
      "properties": {
        "label": {"type": "string", "minLength": 2},
        "description": {"type": "string", "minLength": 10},
        "context_frame": {"type": "string", "minLength": 4}
      }
    },
    "operational_translation": {
      "type": "object",
      "required": [
        "construct",
        "domain",
        "non_literal_boundary",
        "translation_method"
      ],
      "additionalProperties": false,
      "properties": {
        "construct": {"type": "string", "minLength": 4},
        "domain": {
          "type": "string",
          "enum": [
            "cognition",
            "nervous_system_model",
            "human_ai_sensemaking",
            "medical_ai_evidence_organization",
            "animal_care_evidence_organization",
            "scientific_reasoning",
            "privacy_preserving_longitudinal_data"
          ]
        },
        "non_literal_boundary": {"type": "string", "minLength": 10},
        "translation_method": {"type": "string", "minLength": 10}
      }
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "definition", "measurement_type", "expected_direction"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "minLength": 2},
          "definition": {"type": "string", "minLength": 10},
          "measurement_type": {
            "type": "string",
            "enum": ["count", "binary", "ordinal", "continuous", "categorical", "free_text_coded"]
          },
          "expected_direction": {"type": "string", "minLength": 3}
        }
      }
    },
    "uncertainty_notes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 8}
    },
    "missingness": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 4}
    },
    "falsification_route": {
      "type": "string",
      "minLength": 20
    },
    "boundary_risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "literalizing_symbol",
          "medical_or_veterinary_advice_leakage",
          "private_detail_leakage",
          "unsupported_causality",
          "unmeasurable_variable",
          "missing_source_boundary"
        ]
      }
    },
    "next_executable_action": {
      "type": "string",
      "minLength": 12
    }
  }
}
