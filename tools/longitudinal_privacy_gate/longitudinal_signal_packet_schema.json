{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirror-cartographer.local/schemas/longitudinal_signal_packet_schema.json",
  "title": "Longitudinal Signal Packet",
  "description": "Public-safe schema for storing longitudinal pattern signals without raw private details. This supports discovery infrastructure, not diagnosis, treatment, or veterinary advice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "source_status",
    "claim_status",
    "privacy_status",
    "revision_reason",
    "implementation_status",
    "testability",
    "time_index",
    "signal_domain",
    "observable_variables",
    "context_boundaries",
    "missingness",
    "hypothesis_link",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "packet_id": {
      "type": "string",
      "pattern": "^lsp_[a-z0-9_\\-]{8,80}$"
    },
    "source_status": {
      "type": "string",
      "enum": ["synthetic", "public_dataset", "public_literature", "deidentified_user_derived", "unknown"]
    },
    "claim_status": {
      "type": "string",
      "enum": ["observation", "candidate_hypothesis", "mechanistic_model", "prediction", "test_result", "inconclusive", "contradicted", "supported"]
    },
    "privacy_status": {
      "type": "string",
      "enum": ["public_safe", "deidentified", "private_blocked"]
    },
    "revision_reason": { "type": "string", "minLength": 12 },
    "implementation_status": {
      "type": "string",
      "enum": ["fixture", "prototype", "validated", "rejected"]
    },
    "testability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_testable", "test_type", "acceptance_criteria"],
      "properties": {
        "is_testable": { "type": "boolean" },
        "test_type": {
          "type": "string",
          "enum": ["schema_validation", "longitudinal_trend_check", "contradiction_check", "privacy_check", "human_review"]
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 8 }
        }
      }
    },
    "time_index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["granularity", "sequence_label", "absolute_time_removed"],
      "properties": {
        "granularity": { "type": "string", "enum": ["event_order", "day_index", "week_index", "month_index", "study_visit"] },
        "sequence_label": { "type": "string", "minLength": 2, "maxLength": 80 },
        "absolute_time_removed": { "type": "boolean", "const": true }
      }
    },
    "signal_domain": {
      "type": "string",
      "enum": [
        "scientific_reasoning",
        "medical_ai_evidence_organization",
        "animal_care_evidence_organization",
        "nervous_system_modeling",
        "human_ai_sensemaking",
        "symbolic_to_operational_translation",
        "collaboration_readiness"
      ]
    },
    "observable_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "operational_definition", "value_type", "unit_or_scale", "collection_method"],
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 80 },
          "operational_definition": { "type": "string", "minLength": 16 },
          "value_type": { "type": "string", "enum": ["binary", "ordinal", "count", "duration", "ratio", "category", "text_label"] },
          "unit_or_scale": { "type": "string", "minLength": 2, "maxLength": 80 },
          "collection_method": { "type": "string", "minLength": 8, "maxLength": 160 }
        }
      }
    },
    "context_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["excluded_private_fields", "allowed_public_abstractions", "advice_boundary"],
      "properties": {
        "excluded_private_fields": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "raw_transcript" }
        },
        "allowed_public_abstractions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3 }
        },
        "advice_boundary": {
          "type": "string",
          "enum": ["research_organization_only", "question_prep_only", "not_applicable"]
        }
      }
    },
    "missingness": {
      "type": "array",
      "items": { "type": "string", "minLength": 4 }
    },
    "hypothesis_link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothesis_id", "relationship"],
      "properties": {
        "hypothesis_id": { "type": "string", "pattern": "^hyp_[a-z0-9_\\-]{6,80}$" },
        "relationship": { "type": "string", "enum": ["supports", "weakens", "tests", "generates", "contradicts"] }
      }
    },
    "falsification_route": { "type": "string", "minLength": 16 },
    "next_executable_action": { "type": "string", "minLength": 16 }
  }
}
