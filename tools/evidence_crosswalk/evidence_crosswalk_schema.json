{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirror-cartographer.local/schemas/evidence_crosswalk_schema.json",
  "title": "Mirror Cartographer Evidence Crosswalk Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "id",
    "claim_reference",
    "evidence_source",
    "source_status",
    "claim_status",
    "privacy_status",
    "implementation_status",
    "evidence_strength",
    "reproducibility",
    "measurable_variables",
    "limitations",
    "falsification_route",
    "linked_tests",
    "revision_reason"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_type": {"const": "evidence_crosswalk"},
    "id": {"type": "string", "pattern": "^ecw_[a-z0-9_\\-]{6,80}$"},
    "claim_reference": {"type": "string", "minLength": 8, "maxLength": 160},
    "evidence_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "identifier", "version"],
      "properties": {
        "type": {"enum": ["paper", "dataset", "benchmark", "repository", "institution", "protocol", "synthetic_fixture"]},
        "identifier": {"type": "string", "minLength": 3, "maxLength": 240},
        "version": {"type": "string", "minLength": 1, "maxLength": 80}
      }
    },
    "source_status": {"enum": ["primary", "secondary", "preprint", "institutional", "synthetic"]},
    "claim_status": {"enum": ["observational", "supported", "contradicted", "inconclusive"]},
    "privacy_status": {"enum": ["public", "deidentified", "synthetic"]},
    "implementation_status": {"enum": ["planned", "implemented", "validated", "rejected"]},
    "evidence_strength": {"enum": ["low", "moderate", "high"]},
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts_available", "open_data", "open_code"],
      "properties": {
        "artifacts_available": {"type": "boolean"},
        "open_data": {"type": "boolean"},
        "open_code": {"type": "boolean"}
      }
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "units", "measurement_method"],
        "properties": {
          "name": {"type": "string", "minLength": 2, "maxLength": 80},
          "units": {"type": "string", "minLength": 1, "maxLength": 40},
          "measurement_method": {"type": "string", "minLength": 5, "maxLength": 180}
        }
      }
    },
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 5, "maxLength": 240}},
    "falsification_route": {"type": "string", "minLength": 12, "maxLength": 400},
    "linked_tests": {"type": "array", "items": {"type": "string", "minLength": 3, "maxLength": 160}},
    "revision_reason": {"type": "string", "minLength": 8, "maxLength": 240}
  }
}
