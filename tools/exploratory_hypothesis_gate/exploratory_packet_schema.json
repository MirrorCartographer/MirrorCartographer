{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirror-cartographer.local/schemas/exploratory_hypothesis_gate.json",
  "title": "Mirror Cartographer Exploratory Hypothesis Gate Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "research_question",
    "dataset_boundary",
    "measurable_variables",
    "exploratory_steps",
    "hypothesis_updates",
    "validation_plan",
    "falsification_route",
    "evidence_strength",
    "implementation_status",
    "testability",
    "next_executable_action"
  ],
  "properties": {
    "packet_id": { "type": "string", "minLength": 8 },
    "source_status": { "enum": ["synthetic", "public_source", "private_source_redacted", "mixed_public_synthetic"] },
    "claim_status": { "enum": ["infrastructure_hypothesis", "research_organization", "unsupported", "validated_in_fixture_only"] },
    "privacy_status": { "enum": ["public_safe", "redacted", "reject_raw_private_data"] },
    "missingness": { "type": "array", "items": { "type": "string", "minLength": 3 }, "minItems": 1 },
    "revision_reason": { "type": "string", "minLength": 12 },
    "research_question": { "type": "string", "minLength": 20 },
    "dataset_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_inputs", "excluded_inputs", "time_boundary", "population_or_system_boundary"],
      "properties": {
        "allowed_inputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "excluded_inputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "time_boundary": { "type": "string", "minLength": 4 },
        "population_or_system_boundary": { "type": "string", "minLength": 6 }
      }
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "unit_or_scale", "measurement_method", "expected_direction"],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "unit_or_scale": { "type": "string", "minLength": 2 },
          "measurement_method": { "type": "string", "minLength": 5 },
          "expected_direction": { "enum": ["increase", "decrease", "nonlinear", "unknown"] }
        }
      }
    },
    "exploratory_steps": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "purpose", "artifact_expected"],
        "properties": {
          "step": { "type": "string", "minLength": 4 },
          "purpose": { "type": "string", "minLength": 8 },
          "artifact_expected": { "type": "string", "minLength": 5 }
        }
      }
    },
    "hypothesis_updates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "claim", "evidence_delta", "decision"],
        "properties": {
          "stage": { "type": "string", "minLength": 3 },
          "claim": { "type": "string", "minLength": 12 },
          "evidence_delta": { "type": "string", "minLength": 8 },
          "decision": { "enum": ["promote", "hold", "revise", "reject"] }
        }
      }
    },
    "validation_plan": { "type": "string", "minLength": 20 },
    "falsification_route": { "type": "string", "minLength": 20 },
    "evidence_strength": { "enum": ["weak", "moderate", "strong", "fixture_only"] },
    "implementation_status": { "enum": ["schema_only", "validator_ready", "prototype_ready", "production_ready"] },
    "testability": { "type": "string", "minLength": 10 },
    "next_executable_action": { "type": "string", "minLength": 10 }
  }
}
