{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/longitudinal_missingness_packet.schema.json",
  "title": "MC Longitudinal Missingness Packet",
  "description": "Public-safe schema for distinguishing absence from unknown, uncollected, not-applicable, and redacted longitudinal observations before pattern inference.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "hypothesis_id",
    "source_status",
    "claim_status",
    "privacy_status",
    "revision_reason",
    "observation_window",
    "variables",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "packet_id": {"type": "string", "pattern": "^lmg-[a-z0-9-]{8,80}$"},
    "hypothesis_id": {"type": "string", "pattern": "^hyp-[a-z0-9-]{6,80}$"},
    "source_status": {"enum": ["synthetic", "public_dataset", "peer_reviewed", "institutional", "preprint", "mixed_public"]},
    "claim_status": {"enum": ["testable_infrastructure_claim", "unsupported", "inconclusive", "supported", "contradicted"]},
    "privacy_status": {"enum": ["public_safe_synthetic", "public_safe_deidentified", "public"]},
    "revision_reason": {"type": "string", "minLength": 12},
    "observation_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_index", "end_index", "time_unit"],
      "properties": {
        "start_index": {"type": "integer", "minimum": 0},
        "end_index": {"type": "integer", "minimum": 0},
        "time_unit": {"enum": ["hour", "day", "week", "session", "visit"]}
      }
    },
    "variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "unit", "expected_cadence", "values"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,60}$"},
          "unit": {"type": "string", "minLength": 1},
          "expected_cadence": {"enum": ["hourly", "daily", "weekly", "per_session", "per_visit"]},
          "values": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["t", "state"],
              "properties": {
                "t": {"type": "integer", "minimum": 0},
                "state": {"enum": ["observed", "absent", "unknown", "not_collected", "not_applicable", "redacted"]},
                "value": {"type": ["number", "string", "boolean", "null"]},
                "reason": {"type": "string"},
                "source_ref": {"type": "string"}
              },
              "allOf": [
                {
                  "if": {"properties": {"state": {"const": "observed"}}},
                  "then": {"required": ["value"]}
                },
                {
                  "if": {"properties": {"state": {"enum": ["unknown", "not_collected", "redacted"]}}},
                  "then": {"required": ["reason"]}
                }
              ]
            }
          }
        }
      }
    },
    "measurable_variables": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "falsification_route": {"type": "string", "minLength": 20},
    "next_executable_action": {"type": "string", "minLength": 12}
  }
}
