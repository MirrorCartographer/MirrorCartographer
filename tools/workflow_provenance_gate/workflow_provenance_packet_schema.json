{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/workflow_provenance_packet_schema.json",
  "title": "Mirror Cartographer Workflow Provenance Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "hypothesis_id",
    "workflow_stage",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "implementation_status",
    "evidence_strength",
    "agent_actions",
    "evidence_objects",
    "validation_objects",
    "measurable_variables",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "packet_id": {"type": "string", "minLength": 8},
    "hypothesis_id": {"type": "string", "minLength": 8},
    "workflow_stage": {
      "type": "string",
      "enum": [
        "unresolved_phenomenon_map",
        "hypothesis_generation",
        "mechanistic_model",
        "falsifiable_prediction",
        "dataset_or_fixture",
        "evaluation_harness",
        "prototype_tool",
        "evidence_crosswalk",
        "collaborator_path",
        "contradiction_ledger"
      ]
    },
    "source_status": {
      "type": "string",
      "enum": ["primary", "institutional", "preprint", "benchmark", "dataset", "repository", "synthetic", "mixed"]
    },
    "claim_status": {
      "type": "string",
      "enum": ["candidate", "bounded", "supported", "contradicted", "inconclusive", "rejected"]
    },
    "privacy_status": {
      "type": "string",
      "enum": ["public_safe", "deidentified", "synthetic_only", "blocked_private"]
    },
    "missingness": {
      "type": "array",
      "items": {"type": "string", "minLength": 3},
      "minItems": 1
    },
    "revision_reason": {"type": "string", "minLength": 10},
    "implementation_status": {
      "type": "string",
      "enum": ["specified", "implemented", "validated", "blocked"]
    },
    "evidence_strength": {
      "type": "string",
      "enum": ["low", "moderate", "high"]
    },
    "agent_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action_id", "actor", "action_type", "input_boundary", "output_artifact", "timestamp_status"],
        "properties": {
          "action_id": {"type": "string", "minLength": 3},
          "actor": {"type": "string", "enum": ["human", "ai", "tool", "mixed"]},
          "action_type": {"type": "string", "enum": ["search", "retrieve", "extract", "transform", "score", "validate", "commit", "reject"]},
          "input_boundary": {"type": "string", "enum": ["public", "synthetic", "deidentified", "private_blocked"]},
          "output_artifact": {"type": "string", "minLength": 3},
          "timestamp_status": {"type": "string", "enum": ["explicit", "derived", "unknown"]}
        }
      }
    },
    "evidence_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "source_type", "source_locator", "claim_supported", "limitations"],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 3},
          "source_type": {"type": "string", "enum": ["paper", "institution", "benchmark", "dataset", "repository", "preprint", "synthetic_fixture"]},
          "source_locator": {"type": "string", "minLength": 3},
          "claim_supported": {"type": "string", "minLength": 10},
          "limitations": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    },
    "validation_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["validation_id", "validation_type", "pass_condition", "failure_condition"],
        "properties": {
          "validation_id": {"type": "string", "minLength": 3},
          "validation_type": {"type": "string", "enum": ["schema", "unit_test", "crosswalk", "human_review", "benchmark", "replication"]},
          "pass_condition": {"type": "string", "minLength": 10},
          "failure_condition": {"type": "string", "minLength": 10}
        }
      }
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "measurement_method", "unit_or_scale"],
        "properties": {
          "name": {"type": "string", "minLength": 3},
          "measurement_method": {"type": "string", "minLength": 5},
          "unit_or_scale": {"type": "string", "minLength": 1}
        }
      }
    },
    "falsification_route": {"type": "string", "minLength": 20},
    "next_executable_action": {"type": "string", "minLength": 10}
  }
}
