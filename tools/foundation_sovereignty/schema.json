{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.example/schemas/foundation-sovereignty-receipt.v1.json",
  "title": "Foundation Sovereignty Receipt",
  "type": "object",
  "required": [
    "schema",
    "receipt_id",
    "capability",
    "authority",
    "ownership_boundary",
    "external_dependencies",
    "exit_paths",
    "adversarial_evidence",
    "remaining_risks",
    "next_falsifiable_step",
    "continuity",
    "receipt_digest"
  ],
  "properties": {
    "schema": {"const": "foundation.sovereignty-receipt.v1"},
    "receipt_id": {"type": "string", "minLength": 1},
    "capability": {"type": "string", "minLength": 1},
    "authority": {"const": "foundation"},
    "ownership_boundary": {
      "type": "object",
      "required": ["software_control_plane", "not_claimed"],
      "properties": {
        "software_control_plane": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "not_claimed": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "external_dependencies": {"type": "array", "items": {"type": "string"}},
    "exit_paths": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "adversarial_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "test", "result"],
        "properties": {
          "claim": {"type": "string"},
          "test": {"type": "string"},
          "result": {"enum": ["pass", "fail", "unresolved"]}
        }
      }
    },
    "remaining_risks": {"type": "array", "items": {"type": "string"}},
    "next_falsifiable_step": {"type": "string", "minLength": 1},
    "continuity": {
      "type": "object",
      "required": ["parent_receipt_digest", "generation", "public_views_added"],
      "properties": {
        "parent_receipt_digest": {"type": ["string", "null"]},
        "generation": {"type": "integer", "minimum": 1},
        "public_views_added": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "string"}}
      }
    },
    "receipt_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  },
  "additionalProperties": true
}
