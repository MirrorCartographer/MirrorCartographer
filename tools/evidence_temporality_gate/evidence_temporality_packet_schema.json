{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.local/schemas/evidence_temporality_packet_schema.json",
  "title": "MC Evidence Temporality Packet",
  "description": "Public-safe schema for testing whether a research-organization packet preserves temporal order, evidence status, missingness, and non-advice boundaries before any longitudinal or causal-sequence interpretation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "hypothesis_claim",
    "domain",
    "source_status",
    "claim_status",
    "privacy_status",
    "revision_reason",
    "events",
    "temporal_question",
    "measurable_variables",
    "missingness_policy",
    "boundary_policy",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "pattern": "^etg-[a-z0-9-]+$"
    },
    "hypothesis_claim": {
      "type": "string",
      "minLength": 20
    },
    "domain": {
      "type": "string",
      "enum": [
        "cure_discovery_infrastructure",
        "medical_ai_evidence_organization",
        "scientific_reasoning",
        "nervous_system_cognition_models",
        "animal_care_evidence_maps",
        "human_ai_sensemaking",
        "privacy_preserving_longitudinal_datasets",
        "symbolic_to_operational_translation"
      ]
    },
    "source_status": {
      "type": "string",
      "enum": ["synthetic_fixture", "user_stated", "tool_output", "literature_derived", "mixed_public_safe"]
    },
    "claim_status": {
      "type": "string",
      "enum": ["hypothesis", "question_prep", "research_organization", "simulation_only"]
    },
    "privacy_status": {
      "type": "string",
      "enum": ["public_safe", "deidentified", "private_rejected"]
    },
    "revision_reason": {
      "type": "string",
      "minLength": 20
    },
    "temporal_question": {
      "type": "string",
      "minLength": 20
    },
    "events": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "label",
          "time_anchor",
          "time_status",
          "evidence_status",
          "missingness_state",
          "measured_variables",
          "source_ref"
        ],
        "properties": {
          "event_id": {"type": "string", "pattern": "^event-[a-z0-9-]+$"},
          "label": {"type": "string", "minLength": 3},
          "time_anchor": {
            "type": ["string", "null"],
            "description": "ISO-8601 timestamp/date if known; null when time_status is unknown or not_collected."
          },
          "time_status": {
            "type": "string",
            "enum": ["known", "estimated", "unknown", "not_collected", "redacted"]
          },
          "evidence_status": {
            "type": "string",
            "enum": ["observed", "reported", "inferred", "synthetic", "absent", "not_assessed"]
          },
          "missingness_state": {
            "type": "string",
            "enum": ["observed", "unknown", "not_collected", "redacted", "not_applicable"]
          },
          "measured_variables": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "value_status", "unit", "instrument_or_method"],
              "properties": {
                "name": {"type": "string", "minLength": 2},
                "value_status": {"type": "string", "enum": ["measured", "reported", "estimated", "missing", "not_applicable"]},
                "unit": {"type": ["string", "null"]},
                "instrument_or_method": {"type": "string", "minLength": 3}
              }
            }
          },
          "source_ref": {"type": "string", "minLength": 3}
        }
      }
    },
    "measurable_variables": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string", "minLength": 2}
    },
    "missingness_policy": {
      "type": "string",
      "enum": ["unknown_is_not_absent", "not_collected_is_not_negative_evidence"]
    },
    "boundary_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["no_diagnosis", "no_treatment", "no_veterinary_advice", "public_safe_only"],
      "properties": {
        "no_diagnosis": {"type": "boolean", "const": true},
        "no_treatment": {"type": "boolean", "const": true},
        "no_veterinary_advice": {"type": "boolean", "const": true},
        "public_safe_only": {"type": "boolean", "const": true}
      }
    },
    "falsification_route": {
      "type": "string",
      "minLength": 20
    },
    "next_executable_action": {
      "type": "string",
      "minLength": 10
    }
  }
}
