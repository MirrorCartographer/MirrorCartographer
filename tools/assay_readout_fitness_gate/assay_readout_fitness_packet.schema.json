{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/assay_readout_fitness_packet.schema.json",
  "title": "Assay Readout Fitness Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "source_status",
    "claim_status",
    "privacy_status",
    "missingness",
    "revision_reason",
    "implementation_status",
    "evidence_strength",
    "hypothesis",
    "mechanism_claim",
    "assay_or_readout",
    "readout_fitness",
    "confounders",
    "negative_controls",
    "decision_thresholds",
    "falsification_route",
    "next_executable_action"
  ],
  "properties": {
    "packet_id": {"type": "string", "minLength": 8},
    "source_status": {"enum": ["primary", "institutional", "preprint", "benchmark", "open_source", "mixed", "synthetic"]},
    "claim_status": {"enum": ["hypothesis", "evaluation_criterion", "schema", "prototype_requirement", "collaborator_target", "source_map"]},
    "privacy_status": {"enum": ["public_safe", "deidentified_only", "sensitive_blocked", "local_only", "unknown_reject"]},
    "missingness": {"type": "object", "required": ["known_missing", "effect_on_interpretation"], "additionalProperties": false, "properties": {"known_missing": {"type": "array", "items": {"type": "string"}}, "effect_on_interpretation": {"type": "string", "minLength": 12}}},
    "revision_reason": {"type": "string", "minLength": 12},
    "implementation_status": {"enum": ["proposed", "schema_committed", "validator_committed", "tested", "production_wired"]},
    "evidence_strength": {"enum": ["weak", "moderate", "strong"]},
    "hypothesis": {"type": "string", "minLength": 20},
    "mechanism_claim": {"type": "string", "minLength": 20},
    "assay_or_readout": {"type": "object", "required": ["modality", "measurement", "sampling_window", "unit_or_scale"], "additionalProperties": false, "properties": {"modality": {"type": "string", "minLength": 3}, "measurement": {"type": "string", "minLength": 5}, "sampling_window": {"type": "string", "minLength": 3}, "unit_or_scale": {"type": "string", "minLength": 1}}},
    "readout_fitness": {"type": "object", "required": ["distinguishes_mechanism_from_proxy", "specificity_rationale", "sensitivity_rationale", "temporal_alignment", "minimum_viable_evidence"], "additionalProperties": false, "properties": {"distinguishes_mechanism_from_proxy": {"type": "boolean"}, "specificity_rationale": {"type": "string", "minLength": 15}, "sensitivity_rationale": {"type": "string", "minLength": 15}, "temporal_alignment": {"type": "string", "minLength": 15}, "minimum_viable_evidence": {"type": "string", "minLength": 15}}},
    "confounders": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "negative_controls": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "decision_thresholds": {"type": "object", "required": ["promote", "hold", "reject"], "additionalProperties": false, "properties": {"promote": {"type": "string", "minLength": 12}, "hold": {"type": "string", "minLength": 12}, "reject": {"type": "string", "minLength": 12}}},
    "falsification_route": {"type": "string", "minLength": 20},
    "next_executable_action": {"type": "string", "minLength": 12}
  }
}
