{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/decision-event.schema.json",
  "title": "Mirror Cartographer Decision Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "subject_id",
    "event_type",
    "claim_state",
    "valid_time",
    "transaction_time",
    "summary",
    "sources",
    "privacy",
    "review_route"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "event_id": {"type": "string", "pattern": "^DE-[0-9]{4}$"},
    "subject_id": {"type": "string", "minLength": 1},
    "event_type": {"enum": ["observe", "infer", "propose", "correct", "supersede", "resolve", "reopen"]},
    "claim_state": {"enum": ["observed", "inferred", "proposed", "superseded", "unresolved", "resolved"]},
    "valid_time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from"],
      "properties": {
        "from": {"type": "string", "format": "date-time"},
        "to": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "transaction_time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recorded_at"],
      "properties": {
        "recorded_at": {"type": "string", "format": "date-time"},
        "recorded_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "summary": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "locator", "content_sha"],
        "properties": {
          "type": {"enum": ["github_file", "github_commit", "public_document", "restricted_reference"]},
          "locator": {"type": "string", "minLength": 1},
          "content_sha": {"type": ["string", "null"]},
          "observed_at": {"type": ["string", "null"], "format": "date-time"}
        }
      }
    },
    "supersedes_event_ids": {"type": "array", "items": {"type": "string", "pattern": "^DE-[0-9]{4}$"}},
    "contradicts_event_ids": {"type": "array", "items": {"type": "string", "pattern": "^DE-[0-9]{4}$"}},
    "privacy": {"enum": ["public_repository_safe", "restricted_reference_only", "do_not_publish"]},
    "review_route": {"type": "string", "minLength": 1}
  }
}
