{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/fixture-pack.v1.schema.json",
  "title": "MC Fixture Pack Manifest v1",
  "description": "Governed manifest for cross-runtime validation fixture packs. This schema makes fixture-pack authority explicit before Python and Node receipt generators run. It validates public-safe infrastructure evidence only; it does not encode personal material, symbolic truth, or reviewer conclusions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_pack_id",
    "purpose",
    "dialect",
    "authority_policy",
    "runtime_coverage",
    "paths",
    "fixtures",
    "ordering_policy",
    "ci_guardrails"
  ],
  "properties": {
    "schema_version": { "const": "fixture-pack.v1" },
    "fixture_pack_id": {
      "type": "string",
      "pattern": "^fixture-pack-[a-z0-9-]{8,96}$",
      "description": "Stable identifier for this fixture pack. Use a public-safe slug; do not include private scenario text."
    },
    "purpose": {
      "type": "string",
      "minLength": 20,
      "description": "Public-safe statement of what parity behavior this fixture pack proves."
    },
    "dialect": {
      "const": "https://json-schema.org/draft/2020-12/schema"
    },
    "authority_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_is_source_of_truth",
        "undeclared_files_fail_ci",
        "raw_shapes_may_diverge",
        "convergence_layer",
        "private_material_policy"
      ],
      "properties": {
        "manifest_is_source_of_truth": { "const": true },
        "undeclared_files_fail_ci": { "const": true },
        "raw_shapes_may_diverge": { "const": true },
        "convergence_layer": { "const": "canonical_repair_category_set" },
        "private_material_policy": { "const": "fixtures_are_public_safe_and_abstracted" }
      }
    },
    "runtime_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_runtimes", "validator_ids"],
      "properties": {
        "required_runtimes": {
          "type": "array",
          "prefixItems": [
            { "const": "node" },
            { "const": "python" }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "validator_ids": {
          "type": "array",
          "prefixItems": [
            { "const": "ajv" },
            { "const": "python-jsonschema" }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_root",
        "raw_capture_root",
        "expected_receipt_root",
        "schema_root",
        "repair_category_map_path"
      ],
      "properties": {
        "fixture_root": { "const": "mind/fixtures/agency-validation" },
        "raw_capture_root": { "const": "mind/fixtures/agency-validation/raw-captures" },
        "expected_receipt_root": { "const": "mind/fixtures/agency-validation/expected-receipts" },
        "schema_root": { "const": "mind/schemas" },
        "repair_category_map_path": { "const": "mind/config/repair-category-map.v1.json" }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fixture" }
    },
    "ordering_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_sort", "expected_category_sort", "object_key_sort"],
      "properties": {
        "fixture_sort": { "const": "fixture_id_ascending" },
        "expected_category_sort": { "const": "category_id_ascending" },
        "object_key_sort": { "const": "lexicographic_recursive" }
      }
    },
    "ci_guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validate_manifest_before_receipts",
        "validate_paths_with_path_authority",
        "compare_categories_not_messages",
        "reject_missing_runtime_capture",
        "reject_unexpected_runtime_capture",
        "no_network_required"
      ],
      "properties": {
        "validate_manifest_before_receipts": { "const": true },
        "validate_paths_with_path_authority": { "const": true },
        "compare_categories_not_messages": { "const": true },
        "reject_missing_runtime_capture": { "const": true },
        "reject_unexpected_runtime_capture": { "const": true },
        "no_network_required": { "const": true },
        "note": { "type": "string" }
      }
    }
  },
  "$defs": {
    "safe_repo_json_path": {
      "type": "string",
      "pattern": "^mind/[A-Za-z0-9._/-]+\\.json$",
      "not": { "pattern": "(^|/)\\.\\.(?:/|$)" },
      "description": "Repo-relative JSON path under mind/. Absolute paths, traversal segments, and non-JSON files are rejected. Full canonicalization remains the job of path authority."
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "description",
        "instance_path",
        "schema_ref",
        "raw_captures",
        "expected_receipt_path",
        "expected_category_set",
        "negative_space"
      ],
      "properties": {
        "fixture_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,80}$"
        },
        "description": {
          "type": "string",
          "minLength": 20
        },
        "instance_path": { "$ref": "#/$defs/safe_repo_json_path" },
        "instance_hash": { "$ref": "#/$defs/sha256" },
        "schema_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_id", "schema_path"],
          "properties": {
            "schema_id": {
              "type": "string",
              "format": "uri"
            },
            "schema_path": { "$ref": "#/$defs/safe_repo_json_path" },
            "schema_hash": { "$ref": "#/$defs/sha256" }
          }
        },
        "raw_captures": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/runtime_capture" },
          "contains": {
            "type": "object",
            "required": ["runtime", "validator_id"],
            "properties": {
              "runtime": { "const": "node" },
              "validator_id": { "const": "ajv" }
            }
          },
          "minContains": 1,
          "maxContains": 1
        },
        "expected_receipt_path": { "$ref": "#/$defs/safe_repo_json_path" },
        "expected_receipt_hash": { "$ref": "#/$defs/sha256" },
        "expected_category_set": {
          "type": "array",
          "description": "Sorted ascending by category_id. Valid fixtures use an empty array.",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "negative_space": {
          "type": "array",
          "description": "Public-safe statements of what this fixture must not be interpreted to prove.",
          "minItems": 1,
          "items": { "type": "string", "minLength": 10 }
        }
      },
      "allOf": [
        {
          "properties": {
            "raw_captures": {
              "contains": {
                "type": "object",
                "required": ["runtime", "validator_id"],
                "properties": {
                  "runtime": { "const": "python" },
                  "validator_id": { "const": "python-jsonschema" }
                }
              },
              "minContains": 1,
              "maxContains": 1
            }
          }
        }
      ]
    },
    "runtime_capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "validator_id", "raw_capture_path", "capture_id"],
      "properties": {
        "runtime": { "enum": ["node", "python"] },
        "validator_id": { "enum": ["ajv", "python-jsonschema"] },
        "raw_capture_path": { "$ref": "#/$defs/safe_repo_json_path" },
        "capture_id": {
          "type": "string",
          "pattern": "^rvec-[a-z0-9-]{8,96}$"
        },
        "raw_capture_hash": { "$ref": "#/$defs/sha256" },
        "expected_raw_divergence": {
          "type": "string",
          "description": "Optional public-safe note explaining how this raw shape may differ from the paired runtime while still converging canonically."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "runtime": { "const": "node" } }, "required": ["runtime"] },
          "then": { "properties": { "validator_id": { "const": "ajv" } } }
        },
        {
          "if": { "properties": { "runtime": { "const": "python" } }, "required": ["runtime"] },
          "then": { "properties": { "validator_id": { "const": "python-jsonschema" } } }
        }
      ]
    }
  }
}