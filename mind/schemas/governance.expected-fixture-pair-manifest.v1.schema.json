{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/governance.expected-fixture-pair-manifest.v1.schema.json",
  "title": "Governance Expected Fixture Pair Manifest v1",
  "description": "Public-safe declaration manifest for expected/generated fixture byte comparisons. This schema declares custody inputs only; it does not compare fixture bytes, bless fixtures, or claim provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "generated_root",
    "expected_root",
    "comparison_policy",
    "checks",
    "pairs"
  ],
  "properties": {
    "schema_version": {
      "const": "governance.expected-fixture-pairs.v1"
    },
    "manifest_id": {
      "$ref": "#/$defs/kebabId"
    },
    "generated_root": {
      "$ref": "#/$defs/repositoryRelativeDirectory"
    },
    "expected_root": {
      "$ref": "#/$defs/repositoryRelativeDirectory"
    },
    "comparison_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comparison",
        "unexpected_output_policy",
        "update_policy",
        "path_policy"
      ],
      "properties": {
        "comparison": {
          "const": "byte_sha256"
        },
        "unexpected_output_policy": {
          "const": "reject"
        },
        "update_policy": {
          "const": "verify_only"
        },
        "path_policy": {
          "const": "repository_relative_only"
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_schema_valid",
        "manifest_schema_invalid",
        "pair_matched",
        "pair_drifted",
        "pair_generated_missing",
        "pair_expected_missing",
        "unlisted_generated_output"
      ],
      "properties": {
        "manifest_schema_valid": { "const": "GHF_MANIFEST_SCHEMA_VALID" },
        "manifest_schema_invalid": { "const": "GHF_MANIFEST_SCHEMA_INVALID" },
        "pair_matched": { "const": "GHF_PAIR_MATCHED" },
        "pair_drifted": { "const": "GHF_PAIR_DRIFTED" },
        "pair_generated_missing": { "const": "GHF_PAIR_GENERATED_MISSING" },
        "pair_expected_missing": { "const": "GHF_PAIR_EXPECTED_MISSING" },
        "unlisted_generated_output": { "const": "GHF_UNLISTED_GENERATED_OUTPUT" }
      }
    },
    "pairs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/pairDeclaration"
      }
    }
  },
  "$defs": {
    "kebabId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "repositoryRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?!/)(?!~)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)[A-Za-z0-9._/-]+$"
    },
    "repositoryRelativeDirectory": {
      "allOf": [
        { "$ref": "#/$defs/repositoryRelativePath" },
        { "not": { "pattern": "/$" } }
      ]
    },
    "artifactKind": {
      "enum": [
        "result-json",
        "summary-md",
        "output-record-json",
        "manifest-json",
        "provenance-subject-json"
      ]
    },
    "pairDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "artifact_kind",
        "generated_path",
        "expected_path",
        "comparison",
        "checks"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/kebabId" },
        "descriptor_id": { "$ref": "#/$defs/kebabId" },
        "artifact_kind": { "$ref": "#/$defs/artifactKind" },
        "generated_path": { "$ref": "#/$defs/repositoryRelativePath" },
        "expected_path": { "$ref": "#/$defs/repositoryRelativePath" },
        "comparison": { "const": "byte_sha256" },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "matched",
            "drifted",
            "generated_missing",
            "expected_missing"
          ],
          "properties": {
            "matched": { "const": "GHF_PAIR_MATCHED" },
            "drifted": { "const": "GHF_PAIR_DRIFTED" },
            "generated_missing": { "const": "GHF_PAIR_GENERATED_MISSING" },
            "expected_missing": { "const": "GHF_PAIR_EXPECTED_MISSING" }
          }
        }
      }
    }
  }
}
