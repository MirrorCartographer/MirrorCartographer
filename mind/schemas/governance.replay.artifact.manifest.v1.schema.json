{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/governance.replay.artifact.manifest.v1.schema.json",
  "title": "Governance Replay Artifact Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "artifactKind",
    "producer",
    "summary",
    "exitBehavior",
    "publicSafety",
    "files"
  ],
  "properties": {
    "schema": { "const": "governance.replay.artifact.manifest.v1" },
    "artifactKind": {
      "type": "string",
      "pattern": "^governance\\.[a-z0-9.-]+$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "version", "deterministicPolicy"],
      "properties": {
        "tool": { "type": "string", "pattern": "^[A-Za-z0-9._/-]+$" },
        "version": { "type": "string", "pattern": "^v[0-9]+$" },
        "deterministicPolicy": { "type": "string", "pattern": "^[a-z0-9-]+$" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryStatus", "description"],
      "properties": {
        "primaryStatus": { "enum": ["pass", "warn", "fail"] },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "exitBehavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expectedExitCode", "stableExitPolicy"],
      "properties": {
        "expectedExitCode": { "type": "integer", "minimum": 0, "maximum": 255 },
        "stableExitPolicy": { "type": "string", "pattern": "^[a-z0-9-]+$" }
      }
    },
    "publicSafety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyId", "status", "checks"],
      "properties": {
        "policyId": { "type": "string", "pattern": "^[a-z0-9.-]+$" },
        "status": { "enum": ["pass", "fail"] },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/check" }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/file" }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!~)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)[A-Za-z0-9._/-]+$"
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value", "uri"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "uri": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "mediaType", "bytes", "digest"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "role": { "type": "string", "pattern": "^[a-z0-9.-]+$" },
        "mediaType": { "type": "string", "minLength": 1 },
        "bytes": { "type": "integer", "minimum": 0 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "path", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^GOVERNANCE_ARTIFACT_[A-Z0-9_]+$" },
        "severity": { "enum": ["warning", "error"] },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
