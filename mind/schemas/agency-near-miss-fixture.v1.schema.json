{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/agency-near-miss-fixture.v1.schema.json",
  "title": "MC Agency Near-Miss Fixture v1",
  "description": "Public-safe fixture contract for testing near-miss agency-pressure scenarios. This schema validates structure and required evidence only; it does not decide symbolic truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "schema_version",
    "public_safety_level",
    "scenario_pair",
    "agency_boundary",
    "expected_label_distribution",
    "deterministic_rule_inputs",
    "reviewer_prompt",
    "provenance"
  ],
  "properties": {
    "fixture_id": {
      "type": "string",
      "pattern": "^mc-agency-nearmiss-[0-9]{3}$",
      "description": "Stable public-safe fixture identifier."
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "public_safety_level": {
      "enum": ["abstract", "low_vividness", "public_safe"],
      "description": "Must avoid private/personal content and avoid teaching manipulative tactics."
    },
    "scenario_pair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caution_variant", "suspect_variant", "delta_statement"],
      "properties": {
        "caution_variant": { "$ref": "#/$defs/scenario_variant" },
        "suspect_variant": { "$ref": "#/$defs/scenario_variant" },
        "delta_statement": {
          "type": "string",
          "minLength": 20,
          "description": "Plain-language description of the smallest agency-pressure shift between variants."
        }
      }
    },
    "agency_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundary_type", "preserves_agency_when", "narrows_agency_when", "reversibility"],
      "properties": {
        "boundary_type": {
          "enum": ["choice_pressure", "tone_pressure", "symbolic_framing", "memory_weighting", "recommendation_ranking", "social_transmission", "guardrail_escalation"]
        },
        "preserves_agency_when": { "type": "string", "minLength": 10 },
        "narrows_agency_when": { "type": "string", "minLength": 10 },
        "reversibility": {
          "enum": ["easy_to_reverse", "partly_reversible", "hard_to_reverse"]
        }
      }
    },
    "expected_label_distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_expected", "acceptable_disagreement", "thin_boundary"],
      "properties": {
        "primary_expected": {
          "enum": ["Helpful", "Caution", "Suspect", "Blocked"]
        },
        "acceptable_disagreement": {
          "type": "array",
          "items": { "enum": ["Helpful", "Caution", "Suspect", "Blocked"] },
          "uniqueItems": true,
          "minItems": 0,
          "maxItems": 3
        },
        "thin_boundary": {
          "type": "boolean",
          "description": "True when reviewer disagreement is expected to be meaningful rather than an error."
        }
      }
    },
    "deterministic_rule_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observable_pressure_signals", "tripwire_candidates", "missing_evidence", "must_not_decide"],
      "properties": {
        "observable_pressure_signals": {
          "type": "array",
          "items": { "$ref": "#/$defs/pressure_signal" },
          "minItems": 1
        },
        "tripwire_candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/tripwire" },
          "minItems": 0
        },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "description": "What the checker should ask reviewers to inspect rather than silently infer."
        },
        "must_not_decide": {
          "type": "array",
          "items": { "type": "string", "minLength": 3 },
          "description": "Claims the deterministic layer is not allowed to settle, such as symbolic truth or user intent."
        }
      }
    },
    "reviewer_prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "reviewer_notes", "repair_hint"],
      "properties": {
        "question": { "type": "string", "minLength": 10 },
        "reviewer_notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 5 },
          "minItems": 1
        },
        "repair_hint": {
          "type": "string",
          "minLength": 10,
          "description": "Human-readable guidance shown when validation fails."
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_by", "source_basis", "review_status", "updated_at"],
      "properties": {
        "created_by": { "enum": ["human", "assistant", "human_assistant_collaboration", "synthetic_generator"] },
        "source_basis": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "minItems": 1
        },
        "review_status": { "enum": ["draft", "reviewed", "deprecated"] },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "$defs": {
    "scenario_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label_candidate", "text", "visible_user_choice", "agency_receipt"],
      "properties": {
        "label_candidate": { "enum": ["Helpful", "Caution", "Suspect", "Blocked"] },
        "text": { "type": "string", "minLength": 20, "maxLength": 1200 },
        "visible_user_choice": { "type": "boolean" },
        "agency_receipt": { "type": "string", "minLength": 10 }
      }
    },
    "pressure_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_type", "observed_in", "evidence_quote", "severity_hint"],
      "properties": {
        "signal_type": {
          "enum": ["choice_preserved", "choice_narrowed", "urgency_added", "identity_hook", "certainty_inflated", "alternative_hidden", "memory_overweighted", "social_pressure", "reversibility_reduced"]
        },
        "observed_in": { "enum": ["caution_variant", "suspect_variant", "both"] },
        "evidence_quote": { "type": "string", "minLength": 3, "maxLength": 240 },
        "severity_hint": { "enum": ["low", "medium", "high"] }
      }
    },
    "tripwire": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "condition", "if_triggered"],
      "properties": {
        "rule_id": { "type": "string", "pattern": "^AGENCY-RULE-[0-9]{2}$" },
        "condition": { "type": "string", "minLength": 10 },
        "if_triggered": { "enum": ["flag_for_review", "force_suspect_review", "block_fixture", "request_more_evidence"] }
      }
    }
  }
}
