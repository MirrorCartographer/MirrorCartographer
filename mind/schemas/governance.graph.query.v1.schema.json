{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirror-cartographer.local/schemas/governance.graph.query.v1.schema.json",
  "title": "governance.graph.query.v1",
  "description": "A minimal read-only query document for selecting nodes and traversing typed edges in the generated MC governance graph. This is intentionally smaller than a general graph query language.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query_version",
    "query_id",
    "operation",
    "select",
    "expect"
  ],
  "properties": {
    "query_version": {
      "const": "governance.graph.query.v1"
    },
    "query_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,120}$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "enum": [
        "select_nodes",
        "select_edges",
        "traverse"
      ]
    },
    "select": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target"
      ],
      "properties": {
        "target": {
          "enum": [
            "nodes",
            "edges"
          ]
        },
        "where": {
          "$ref": "#/$defs/where_clause"
        },
        "order_by": {
          "type": "array",
          "items": {
            "enum": [
              "artifact_id",
              "artifact_type",
              "version",
              "edge_type",
              "from",
              "to"
            ]
          },
          "uniqueItems": true,
          "default": [
            "artifact_id"
          ]
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500
        }
      }
    },
    "traverse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_artifact_id",
        "direction",
        "edge_types",
        "max_depth"
      ],
      "properties": {
        "start_artifact_id": {
          "$ref": "#/$defs/artifact_id"
        },
        "direction": {
          "enum": [
            "outbound",
            "inbound"
          ]
        },
        "edge_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/edge_type"
          }
        },
        "max_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "include_start": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "project": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "artifact_id",
          "artifact_type",
          "version",
          "manifest_path",
          "edge_type",
          "from",
          "to",
          "depth"
        ]
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "deterministic_order"
      ],
      "properties": {
        "status": {
          "enum": [
            "pass",
            "fail"
          ]
        },
        "deterministic_order": {
          "const": true
        },
        "error_code": {
          "type": "string",
          "pattern": "^GOVERNANCE_GRAPH_QUERY/[A-Z0-9_]+$"
        },
        "result_shape": {
          "enum": [
            "node_list",
            "edge_list",
            "traversal_list",
            "error"
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": {
            "const": "traverse"
          }
        }
      },
      "then": {
        "required": [
          "traverse"
        ]
      },
      "else": {
        "not": {
          "required": [
            "traverse"
          ]
        }
      }
    }
  ],
  "$defs": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:/-]{2,160}$"
    },
    "edge_type": {
      "enum": [
        "supersedes",
        "derived_from",
        "validated_against",
        "compatible_with",
        "generated_by",
        "uses_fixture"
      ]
    },
    "where_clause": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/artifact_id"
        },
        "artifact_type": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{1,80}$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "edge_type": {
          "$ref": "#/$defs/edge_type"
        },
        "from": {
          "$ref": "#/$defs/artifact_id"
        },
        "to": {
          "$ref": "#/$defs/artifact_id"
        }
      }
    }
  }
}
