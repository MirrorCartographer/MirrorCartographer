{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirrorcartographer.dev/schemas/canonical-repair-receipt.v1.schema.json",
  "title": "MC Canonical Repair Receipt v1",
  "description": "Byte-stable, validator-neutral receipt generated from raw validator captures. CI may compare these receipts for convergence. The receipt preserves evidence references and governed repair categories without depending on validator message wording, raw error ordering, or symbolic truth claims.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "created_at",
    "generator",
    "source_capture",
    "fixture_ref",
    "schema_ref",
    "repair_category_map_ref",
    "validation_result",
    "canonical_repairs",
    "ordering_policy",
    "ci_guardrails"
  ],
  "properties": {
    "schema_version": { "const": "canonical-repair-receipt.v1" },
    "receipt_id": {
      "type": "string",
      "pattern": "^crr-[a-z0-9-]{8,128}$",
      "description": "Stable receipt identifier derived from validator id, fixture id, schema id, source capture id, and canonical repair contents."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC generation timestamp. This field is informational and must not participate in convergence identity."
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "runtime", "algorithm_id"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "runtime": { "enum": ["node", "python", "ci", "unknown"] },
        "algorithm_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "description": "Names the mapping algorithm version, for example repair-receipt-generator.v1."
        }
      }
    },
    "source_capture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "capture_id", "raw_capture_path"],
      "properties": {
        "validator_id": { "enum": ["ajv", "python-jsonschema"] },
        "capture_id": { "type": "string", "pattern": "^rvec-[a-z0-9-]{8,96}$" },
        "raw_capture_path": { "type": "string", "pattern": "^mind/reports/agency-validation/runs/.+/raw/.+\\.json$" },
        "raw_capture_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "fixture_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_id", "path"],
      "properties": {
        "fixture_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^mind/fixtures/.+\\.json$" },
        "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "schema_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "path"],
      "properties": {
        "schema_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^mind/schemas/.+\\.json$" },
        "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "repair_category_map_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "config_path", "config_hash"],
      "properties": {
        "schema_id": { "const": "https://mirrorcartographer.dev/schemas/repair-category-map.v1.schema.json" },
        "config_path": { "const": "mind/config/repair-category-map.v1.json" },
        "config_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid", "raw_error_count", "canonical_repair_count"],
      "properties": {
        "valid": { "type": "boolean" },
        "raw_error_count": { "type": "integer", "minimum": 0 },
        "canonical_repair_count": { "type": "integer", "minimum": 0 }
      }
    },
    "canonical_repairs": {
      "type": "array",
      "description": "Sorted by category_id, instance_pointer, schema_pointer, then first raw_error_id. Valid fixtures must use an empty array.",
      "items": { "$ref": "#/$defs/canonical_repair" }
    },
    "ordering_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_keys", "repair_sort", "raw_error_sort", "array_order_semantics"],
      "properties": {
        "object_keys": { "const": "lexicographic_recursive" },
        "repair_sort": { "const": "category_id_instance_pointer_schema_pointer_first_raw_error_id" },
        "raw_error_sort": { "const": "raw_error_id" },
        "array_order_semantics": { "const": "arrays_preserve_meaning_except_declared_sorted_receipt_arrays" }
      }
    },
    "ci_guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "messages_are_debug_only",
        "raw_order_is_not_convergence",
        "categories_must_exist_in_map",
        "receipt_does_not_claim_symbolic_truth",
        "valid_receipt_can_have_no_repairs"
      ],
      "properties": {
        "messages_are_debug_only": { "const": true },
        "raw_order_is_not_convergence": { "const": true },
        "categories_must_exist_in_map": { "const": true },
        "receipt_does_not_claim_symbolic_truth": { "const": true },
        "valid_receipt_can_have_no_repairs": { "const": true },
        "note": { "type": "string" }
      }
    }
  },
  "$defs": {
    "canonical_repair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repair_id",
        "category_id",
        "mapping_confidence",
        "instance_location",
        "schema_location",
        "evidence_refs",
        "reviewer_repair_prompt",
        "non_meaning"
      ],
      "properties": {
        "repair_id": {
          "type": "string",
          "pattern": "^repair-[a-z0-9-]{8,128}$",
          "description": "Stable ID derived from category, fixture, schema location, instance location, and raw evidence IDs."
        },
        "category_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "mapping_confidence": { "enum": ["direct", "contextual", "boundary", "fallback"] },
        "keyword_basis": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "instance_location": { "$ref": "#/$defs/json_pointer_location" },
        "schema_location": { "$ref": "#/$defs/json_pointer_location" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["raw_error_id", "keyword"],
            "properties": {
              "raw_error_id": { "type": "string", "pattern": "^raw-[a-z0-9-]{8,96}$" },
              "keyword": { "type": "string", "minLength": 1 },
              "nested_raw_error_indexes": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 },
                "uniqueItems": true
              }
            }
          }
        },
        "reviewer_repair_prompt": { "type": "string", "minLength": 10 },
        "non_meaning": { "type": "string", "minLength": 10 },
        "adapter_note": {
          "type": "string",
          "description": "Optional public-safe note about mapping ambiguity or adapter debt. Do not include private scenario content."
        }
      }
    },
    "json_pointer_location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pointer"],
      "properties": {
        "pointer": {
          "type": "string",
          "description": "RFC 6901 JSON Pointer. Root is the empty string."
        },
        "path_segments": {
          "type": "array",
          "items": { "type": ["string", "integer"] }
        }
      }
    }
  }
}
